@model RedRoomDemo.Models.OrderDetailsViewModel

@{
    ViewData["Title"] = "Order Details";
}

<h1 class="mb-3">Order Details</h1>

<div class="card mb-3">
    <div class="card-body">
        <h5 class="card-title">@Model.OrderNumber</h5>
        <p class="mb-1"><strong>OrderId:</strong> @Model.OrderId</p>
        <p class="mb-1"><strong>Customer:</strong> @Model.CustomerName (@Model.CustomerEmail)</p>
        <p class="mb-1"><strong>Total:</strong> @Model.TotalAmount.ToString("C")</p>
        <p class="mb-0"><strong>Status:</strong> @Model.OrderStatus</p>
    </div>
</div>

<div class="alert @(Model.HasPaymentMatch ? "alert-warning" : "alert-danger")">
    <strong>Payment Matching Result:</strong> @Model.PaymentMatchNote
</div>

<h3>Matched Payment Records</h3>
@if (Model.MatchedPayments.Count == 0)
{
    <p>No payment records matched.</p>
}
else
{
    <table class="table table-striped table-bordered align-middle">
        <thead class="table-light">
        <tr>
            <th>TransactionId</th>
            <th>TransactionReference</th>
            <th>PaidAmount</th>
            <th>Status</th>
            <th>CreatedAt</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var payment in Model.MatchedPayments)
        {
            <tr>
                <td>@payment.TransactionId</td>
                <td>@payment.TransactionReference</td>
                <td>@payment.PaidAmount.ToString("C")</td>
                <td>@payment.Status</td>
                <td>@payment.CreatedAt</td>
            </tr>
        }
        </tbody>
    </table>
}

<a class="btn btn-secondary" asp-controller="Orders" asp-action="Index">Back to Orders</a>
