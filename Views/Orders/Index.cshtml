@model IReadOnlyList<RedRoomDemo.Models.OrderListItemViewModel>

@{
    ViewData["Title"] = "Orders";
}

<h1 class="mb-3">Orders</h1>

<table class="table table-striped table-bordered align-middle">
    <thead class="table-light">
    <tr>
        <th>OrderId</th>
        <th>Order Number</th>
        <th>Customer</th>
        <th>Total Amount</th>
        <th>Status</th>
        <th></th>
    </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.OrderId</td>
            <td>@item.OrderNumber</td>
            <td>@item.CustomerName</td>
            <td>@item.TotalAmount.ToString("C")</td>
            <td>@item.Status</td>
            <td>
                <a class="btn btn-sm btn-outline-secondary" asp-controller="Orders" asp-action="Details" asp-route-id="@item.OrderId">Details</a>
            </td>
        </tr>
    }
    </tbody>
</table>
