@model IReadOnlyList<RedRoomDemo.Models.PaymentListItemViewModel>

@{
    ViewData["Title"] = "Payments";
}

<h1 class="mb-3">Payment Transactions</h1>
<p class="text-muted">Legacy note: this system only tries to match payments by TransactionReference to OrderNumber.</p>

<table class="table table-striped table-bordered align-middle">
    <thead class="table-light">
    <tr>
        <th>TransactionId</th>
        <th>Transaction Reference</th>
        <th>Paid Amount</th>
        <th>Status</th>
        <th>CreatedAt</th>
        <th>Match Hint</th>
    </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.TransactionId</td>
            <td>@item.TransactionReference</td>
            <td>@item.PaidAmount.ToString("C")</td>
            <td>@item.Status</td>
            <td>@item.CreatedAt</td>
            <td>@item.MatchHint</td>
        </tr>
    }
    </tbody>
</table>
