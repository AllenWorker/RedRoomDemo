@model IReadOnlyList<RedRoomDemo.Models.PaymentListItemViewModel>

@{
    ViewData["Title"] = "Unmatched Successful Payments";
}

<h1 class="mb-3">Unmatched Successful Payments</h1>
<p class="text-muted">These successful transactions could not be linked to any order by TransactionReference.</p>

<table class="table table-striped table-bordered align-middle">
    <thead class="table-light">
    <tr>
        <th>TransactionId</th>
        <th>Transaction Reference</th>
        <th>Paid Amount</th>
        <th>Status</th>
        <th>CreatedAt</th>
        <th>Warning</th>
    </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.TransactionId</td>
            <td>@item.TransactionReference</td>
            <td>@item.PaidAmount.ToString("C")</td>
            <td>@item.Status</td>
            <td>@item.CreatedAt</td>
            <td>@item.MatchHint</td>
        </tr>
    }
    </tbody>
</table>

<a class="btn btn-outline-secondary" asp-controller="Payments" asp-action="Index">Back to Payment List</a>
